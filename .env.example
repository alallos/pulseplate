# PulsePlate environment variables
# Copy this file to .env in the repo root and replace placeholders with your real values.
# Do not commit .env (it is in .gitignore).

# --- Grok (xAI) - meal plan generation ---
GROK_API_KEY=your_grok_api_key_here

# --- Oura OAuth (for multi-user / production) ---
OURA_CLIENT_ID=your_oura_client_id_here
OURA_CLIENT_SECRET=your_oura_client_secret_here
# Callback URL must match exactly what you registered in Oura Developer Portal
OURA_REDIRECT_URI=http://localhost:8000/auth/oura/callback

# --- Auth & security (JWT + OAuth state signing) ---
# SECRET_KEY is used both to sign OAuth state and to sign JWT session tokens.
# Generate a strong random value and keep it secret.
SECRET_KEY=your_secret_key_here

# --- Optional: Oura webhook verification (must match subscription verification_token if set) ---
# OURA_WEBHOOK_VERIFICATION_TOKEN=

# --- Database (optional: use Postgres in production so data survives redeploys) ---
# When set (e.g. Railway Postgres), app uses PostgreSQL; otherwise SQLite in project root.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Optional: Sentry monitoring (error and performance tracking) ---
# Set SENTRY_DSN to enable Sentry. If unset, Sentry is disabled.
# You can also optionally set:
# - SENTRY_TRACES_SAMPLE_RATE (e.g. 0.2)
# - SENTRY_PROFILES_SAMPLE_RATE
# - SENTRY_ENVIRONMENT (e.g. production, staging)
# SENTRY_DSN=
