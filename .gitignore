# Python-specific ignores (from github/gitignore Python template)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.env/
env.bak/
venv.bak/

# Environment variables & secrets (critical for us!)
.env
.env.local
.env.*.local
.env.development
.env.production
*.env.example  # optional: keep if you want the template committed, but usually .env.example is committed

# FastAPI / Uvicorn extras
*.pid
instance/
.webassets-cache
*.log

# Database files (we start with SQLite)
*.db
*.sqlite3
*.sqlite

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Testing / coverage
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.pytest_cache/
tox/
nox/
.hypothesis/
.pytest_cache/
cover/

# Dependency management extras (if you add poetry/pipenv later)
Pipfile.lock
poetry.lock  # usually commit this, but ignore if you prefer

# Deployment / build artifacts
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# Logs and temp files
*.log
*.logs
tmp/
temp/
